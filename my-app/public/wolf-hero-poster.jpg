<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 720" width="1280" height="720">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a2e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f0f1a;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="moonlight" cx="80%" cy="20%" r="30%">
      <stop offset="0%" style="stop-color:#4a5568;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#1a1a2e;stop-opacity:0" />
    </radialGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1280" height="720" fill="url(#bg)"/>
  <rect width="1280" height="720" fill="url(#moonlight)"/>
  
  <!-- Wolf silhouette - side profile -->
  <g transform="translate(640, 360)" fill="#2d3748">
    <!-- Body -->
    <ellipse cx="0" cy="0" rx="180" ry="80"/>
    
    <!-- Head -->
    <circle cx="160" cy="-40" r="55"/>
    
    <!-- Snout -->
    <ellipse cx="210" cy="-30" rx="30" ry="18"/>
    
    <!-- Ears -->
    <polygon points="140,-85 155,-130 170,-85"/>
    <polygon points="170,-85 185,-130 200,-85"/>
    
    <!-- Front legs -->
    <rect x="80" y="60" width="18" height="100" rx="9"/>
    <rect x="110" y="60" width="18" height="100" rx="9"/>
    
    <!-- Back legs -->
    <rect x="-100" y="60" width="18" height="100" rx="9"/>
    <rect x="-70" y="60" width="18" height="100" rx="9"/>
    
    <!-- Tail -->
    <path d="M-180,-20 Q-250,-60 -280,-20 Q-300,10 -260,30" 
          fill="none" stroke="#2d3748" stroke-width="20" stroke-linecap="round"/>
    
    <!-- Eye -->
    <circle cx="185" cy="-45" r="8" fill="#1a1a2e"/>
    <circle cx="187" cy="-47" r="3" fill="#e2e8f0"/>
    
    <!-- Nose -->
    <ellipse cx="235" cy="-28" rx="6" ry="4" fill="#1a1a2e"/>
  </g>
  
  <!-- Title overlay -->
  <text x="640" y="620" text-anchor="middle" font-family="system-ui, sans-serif" 
        font-size="48" font-weight="bold" fill="#e2e8f0" opacity="0.9">
    WOLF HERO
  </text>
  <text x="640" y="670" text-anchor="middle" font-family="system-ui, sans-serif" 
        font-size="20" fill="#a0aec0" opacity="0.7">
    Scroll-scrubbed video placeholder
  </text>
</svg>
